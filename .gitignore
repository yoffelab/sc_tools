# ---------------------------------------------------------------------------
# sc_tools project .gitignore
# Note: Git cannot ignore by file size. Use the pre-commit hook to block
#       files > 1MB (see .githooks/README.md).
# Layout: root scripts/, sc_tools/; projects/<type>/<name>/ with data, figures,
#         metadata, results, outputs. No root metadata/, results/, figures/.
# ---------------------------------------------------------------------------

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
.venv/
venv/
ENV/
env/

# IDE / editors
.idea/
.vscode/
*.swp
*.swo
*~

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Jupyter
.ipynb_checkpoints/
*.ipynb_checkpoints

# ---------------------------------------------------------------------------
# Large or generated data (often > 1MB) — keep out of repo
# ---------------------------------------------------------------------------
# AnnData / Seurat
*.h5ad
*.h5Seurat
*.rds
*.h5

# Project layout: projects/<data_type>/<project_name>/{data,figures,results,outputs}
projects/visium/*/data/
projects/visium_hd/*/data/
projects/visium_hd_cell/*/data/
projects/xenium/*/data/
projects/imc/*/data/
projects/cosmx_1k/*/data/
projects/cosmx_6k/*/data/
projects/cosmx_full_library/*/data/
projects/multiplatform/*/data/
projects/visium/*/figures/
projects/visium_hd/*/figures/
projects/visium_hd_cell/*/figures/
projects/xenium/*/figures/
projects/imc/*/figures/
projects/cosmx_1k/*/figures/
projects/cosmx_6k/*/figures/
projects/cosmx_full_library/*/figures/
projects/multiplatform/*/figures/
projects/imc/*/images/
projects/imc/*/anndata/
projects/imc/*/documentation/
projects/visium/*/results/
projects/visium_hd/*/results/
projects/visium_hd_cell/*/results/
projects/xenium/*/results/
projects/imc/*/results/
projects/cosmx_1k/*/results/
projects/cosmx_6k/*/results/
projects/cosmx_full_library/*/results/
projects/multiplatform/*/results/
projects/visium/*/outputs/
projects/visium_hd/*/outputs/
projects/visium_hd_cell/*/outputs/
projects/xenium/*/outputs/
projects/imc/*/outputs/
projects/cosmx_1k/*/outputs/
projects/cosmx_6k/*/outputs/
projects/cosmx_full_library/*/outputs/
projects/multiplatform/*/outputs/

# Claude figure analytics (generated by hook; never commit)
*_claude_analytics_and_legend.txt

# Legacy root-level paths (all project-specific now under projects/)
/figures/
/metadata/
/output/
/outputs/
/results/
/data/

# Caches and pickles
*.pickle
*.pkl
*.cache

# Documentation binaries
*.pptx
*.doc
*.docx
*.xlsx
*.pdf

# Whole-slide / images
*.svs
*.tiff
*.tif
*.ndpi

# Compressed
*.zip
*.tar
*.tar.gz
*.gz
*.7z

# Logs and temp
*.log
*.tmp
temp/
tmp/
logs/

# Generated / tooling
repomix-output.xml
.snakemake_lint_done
.snakemake_format_done
.snakemake_test_done

# Apptainer/Singularity SIF (build from Dockerfile; see project_setup.md)
containers/*.sif

# Model weights and large QC/generated (>1MB) — pre-commit blocks size; keep ignored
# Explicit: do not commit CSVs or other data > 1MB (see .cursor/rules/git-no-large-files.mdc)
# Adobe Illustrator / manuscript binary files (always large)
*.ai
*.pt
*web_summary.html
projects/visium_hd/*/models/
projects/visium_hd/*/metadata/qc/
**/old code/*.ipynb

# Project-related metadata (inventory, notebooks, RDS usage, etc.) — do not commit
projects/**/metadata/

# Nested git repos under projects (do not add as submodules by accident)
projects/**/.git/

# Claude Code — local/personal config (not shared)
.claude/settings.local.json
CLAUDE.local.md
.claude/CLAUDE.local.md

# Sphinx documentation build artifacts
docs/_build/
docs/api/generated/

# Obsidian — ignore root workspace state (auto-generated)
/.obsidian/
# Wiki: generated files (sync_wiki.py output, Obsidian vault)
/docs/wiki/
/docs/archive/

# FST files (R data serialization; always large)
*.fst

# Claude Code — local worktrees (session-specific, not shared)
.claude/worktrees/

# IMC projects: project-root-level data files not under data/ subdirectory
# (these projects predate the standard layout; all raw/processed data excluded)
projects/imc/aapc/
projects/imc/clonevo/
projects/imc/ggo-imc/
projects/imc/ggo_human/
projects/imc/healthy_lung/
projects/imc/imc_data/
projects/imc/imc_utuc/
projects/imc/jj_tmp/
projects/imc/pancreas_liver_meta/
projects/imc/*/processed/
projects/imc/bcg_bladder/*.csv
projects/imc/brca-unet/*.csv
projects/imc/brca-unet/*.tsv
projects/imc/brca-unet/*.txt
projects/imc/brca-unet/Code/
projects/imc/lymph_dlbcl/notebooks/
projects/imc/lymph_dlbcl/run_docker.sh
