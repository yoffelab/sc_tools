# ---------------------------------------------------------------------------
# sc_tools project .gitignore
# Note: Git cannot ignore by file size. Use the pre-commit hook to block
#       files > 1MB (see .githooks/README.md).
# Layout: root scripts/, sc_tools/; projects/<type>/<name>/ with data, figures,
#         metadata, results, outputs. No root metadata/, results/, figures/.
# ---------------------------------------------------------------------------

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
.venv/
venv/
ENV/
env/

# IDE / editors
.idea/
.vscode/
*.swp
*.swo
*~

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Jupyter
.ipynb_checkpoints/
*.ipynb_checkpoints

# ---------------------------------------------------------------------------
# Large or generated data (often > 1MB) — keep out of repo
# ---------------------------------------------------------------------------
# AnnData / Seurat
*.h5ad
*.h5Seurat
*.rds
*.h5

# Project layout: projects/<data_type>/<project_name>/{data,figures,results,outputs}
projects/visium/*/data/
projects/visium_hd/*/data/
projects/xenium/*/data/
projects/imc/*/data/
projects/visium/*/figures/
projects/visium_hd/*/figures/
projects/xenium/*/figures/
projects/imc/*/figures/
projects/imc/*/images/
projects/imc/*/anndata/
projects/imc/*/documentation/
projects/visium/*/results/
projects/visium_hd/*/results/
projects/xenium/*/results/
projects/imc/*/results/
projects/visium/*/outputs/
projects/visium_hd/*/outputs/
projects/xenium/*/outputs/
projects/imc/*/outputs/

# Legacy root-level paths (all project-specific now under projects/)
/figures/
/metadata/
/output/
/outputs/
/results/
/data/

# Caches and pickles
*.pickle
*.pkl
*.cache

# Documentation binaries
*.pptx
*.docx
*.xlsx
*.pdf

# Whole-slide / images
*.svs
*.tiff
*.tif
*.ndpi

# Compressed
*.zip
*.tar
*.tar.gz
*.gz
*.7z

# Logs and temp
*.log
*.tmp
temp/
tmp/
logs/

# Generated / tooling
repomix-output.xml
.snakemake_lint_done
.snakemake_format_done
.snakemake_test_done

# Apptainer/Singularity SIF (build from Dockerfile; see project_setup.md)
containers/*.sif

# Model weights and large QC/generated (>1MB) — pre-commit blocks size; keep ignored
# Explicit: do not commit CSVs or other data > 1MB (see .cursor/rules/git-no-large-files.mdc)
projects/visium_hd/robin_round2/metadata/cluster_rank_genes.csv
projects/visium_hd/robin_round2/metadata/leiden_rank_genes.csv
*.pt
*web_summary.html
projects/visium_hd/*/models/
projects/visium_hd/*/metadata/qc/
**/old code/*.ipynb

# Project-related metadata (inventory, notebooks, RDS usage, etc.) — do not commit
projects/**/metadata/

# Nested git repos under projects (do not add as submodules by accident)
projects/**/.git/

# Claude Code — local/personal config (not shared)
.claude/settings.local.json
CLAUDE.local.md
.claude/CLAUDE.local.md
