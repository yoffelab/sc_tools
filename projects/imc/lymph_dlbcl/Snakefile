"""
Snakefile: DLBCL IMC Manuscript Reproduction Pipeline

Usage:
    # Full pipeline
    snakemake --cores 8 all

    # Specific phases
    snakemake --cores 8 phase0      # Data audit
    snakemake --cores 8 phase1      # AnnData construction
    snakemake --cores 8 phase2      # QC
    snakemake --cores 8 phase3      # Cell type validation + LME
    snakemake --cores 4 figures     # All figures
    snakemake --cores 1 fig1        # Single figure

    # Dry run
    snakemake -n all

    # On cayuga with container
    ./scripts/run_container.sh . snakemake --cores 8 all
"""

configfile: "config.yaml"

import os
import pandas as pd

PANELS = config["panels"]  # ["immune", "stromal"]

# ── Plan B: raw IMC reprocessing (Phase 0a) ─────────────────────────────────
# Activated only when config.phase0a.enabled == true.
# Requires cayuga access (VPN) and validated raw MCD files.
_PHASE0A = config.get("phase0a", {})
_PHASE0A_ENABLED = _PHASE0A.get("enabled", False)

if _PHASE0A_ENABLED:
    _MANIFEST_IMMUNE = pd.read_csv(_PHASE0A["manifest_immune"], sep="\t")
    _MANIFEST_STROMAL = pd.read_csv(_PHASE0A["manifest_stromal"], sep="\t")
    _PHASE0A_SAMPLES_IMMUNE = _MANIFEST_IMMUNE["sample_id"].tolist()
    _PHASE0A_SAMPLES_STROMAL = _MANIFEST_STROMAL["sample_id"].tolist()
    _IDX_IMMUNE = _MANIFEST_IMMUNE.set_index("sample_id")
    _IDX_STROMAL = _MANIFEST_STROMAL.set_index("sample_id")

# ── Backwards-compat checkpoint resolver (panel-aware) ───────────────────────
# Returns old path when the old file exists and the new one does not.
def _compat(new, old):
    return old if os.path.exists(old) and not os.path.exists(new) else new

# Panel-specific checkpoint paths (drop .p1/.p2/.p4 suffix from old names).
# Usage: ADATA_RAW["immune"], ADATA_ANN["stromal"], etc.
ADATA_RAW = {
    p: _compat(f"results/adata.{p}.raw.h5ad", f"results/adata.{p}.raw.p1.h5ad")
    for p in PANELS
}
ADATA_ANN = {
    p: _compat(f"results/adata.{p}.annotated.h5ad", f"results/adata.{p}.annotated.p2.h5ad")
    for p in PANELS
}
ADATA_CELLTYPED = {
    p: _compat(f"results/adata.{p}.celltyped.h5ad", f"results/adata.{p}.celltyped.p4.h5ad")
    for p in PANELS
}

# ============================================================
# Target rules
# ============================================================

# ============================================================
# Phase 0a: Raw IMC Reprocessing (Plan B — requires cayuga VPN)
# ============================================================
# Enable via: snakemake --config 'phase0a={enabled: true}' phase0a_immune
# or set phase0a.enabled: true in config.yaml.

if _PHASE0A_ENABLED:

    rule phase0a_immune:
        """Run IMC pipeline for all immune-panel samples."""
        input:
            expand(
                _PHASE0A["output_dir"] + "/{sample_id}/.done",
                sample_id=_PHASE0A_SAMPLES_IMMUNE,
            ),

    rule phase0a_stromal:
        """Run IMC pipeline for all stromal-panel samples."""
        input:
            expand(
                _PHASE0A["output_dir"] + "/{sample_id}/.done",
                sample_id=_PHASE0A_SAMPLES_STROMAL,
            ),

    rule run_imc_pipeline:
        """Run steinbock IMC pipeline for a single sample via Apptainer.

        Handles both MCD files and txt-file directories as raw input.
        Input ``mcd_file`` column may be:
          - a path to a ``.mcd`` file, or
          - a path to a directory containing per-ROI ``.txt`` files.

        Pipeline steps (steinbock):
          1. preprocess imc  — extracts per-ROI TIFFs from raw
          2. segment cellpose — cell segmentation on nuclear + membrane markers
          3. measure intensities — per-cell intensity tables
          4. export adata — final cells.h5ad checkpoint

        Setup: pull steinbock SIF once on cayuga with scripts/setup_steinbock.sh.
        """
        input:
            raw=lambda wc: (
                _IDX_IMMUNE.loc[wc.sample_id, "raw_path"]
                if wc.sample_id in _IDX_IMMUNE.index
                else _IDX_STROMAL.loc[wc.sample_id, "raw_path"]
            ),
            panel=lambda wc: (
                _IDX_IMMUNE.loc[wc.sample_id, "panel_csv"]
                if wc.sample_id in _IDX_IMMUNE.index
                else _IDX_STROMAL.loc[wc.sample_id, "panel_csv"]
            ),
        output:
            h5ad=_PHASE0A["output_dir"] + "/{sample_id}/adata/cells.h5ad",
            done=touch(_PHASE0A["output_dir"] + "/{sample_id}/.done"),
        params:
            out_dir=lambda wc: _PHASE0A["output_dir"] + "/" + wc.sample_id,
            sif=_PHASE0A["steinbock_sif"],
        log:
            "outputs/logs/imc_pipeline_{sample_id}.log",
        resources:
            mem_mb=32000,
            cpus=4,
        shell:
            r"""
            set -euo pipefail
            SIF={params.sif}
            OUTDIR={params.out_dir}
            RAW={input.raw}

            # 1. Setup steinbock working directory layout
            mkdir -p "$OUTDIR/raw" "$OUTDIR/img" "$OUTDIR/masks" \
                     "$OUTDIR/intensities" "$OUTDIR/adata"

            # 2. Stage raw input (MCD file or txt directory)
            if [ -f "$RAW" ]; then
                # MCD file: link into raw/
                ln -sf "$(realpath "$RAW")" "$OUTDIR/raw/"
            elif [ -d "$RAW" ]; then
                # txt directory: link all .txt files into raw/
                find "$RAW" -maxdepth 1 -name "*.txt" \
                    -exec ln -sf "$(realpath {{}})" "$OUTDIR/raw/" \;
            else
                echo "ERROR: raw path not found: $RAW" >&2
                exit 1
            fi

            # 3. Convert panel CSV to steinbock format (name/keep/ilastik columns)
            python scripts/convert_panel_for_steinbock.py \
                {input.panel} "$OUTDIR/panel.csv"

            # 4. Preprocess: extract per-ROI TIFFs
            apptainer exec "$SIF" steinbock preprocess imc \
                --panel "$OUTDIR/panel.csv" "$OUTDIR/" \
                >> {log} 2>&1

            # 5. Segment: cell segmentation with Cellpose (nuclear + membrane)
            apptainer exec "$SIF" steinbock segment cellpose \
                --panel "$OUTDIR/panel.csv" \
                --nuclear-channels "HistoneH3" "DNA1" \
                "$OUTDIR/" \
                >> {log} 2>&1

            # 6. Measure per-cell intensities
            apptainer exec "$SIF" steinbock measure intensities \
                --panel "$OUTDIR/panel.csv" "$OUTDIR/" \
                >> {log} 2>&1

            # 7. Export to AnnData h5ad
            apptainer exec "$SIF" steinbock export adata \
                --panel "$OUTDIR/panel.csv" "$OUTDIR/" \
                >> {log} 2>&1

            echo "steinbock pipeline complete: $OUTDIR" >> {log}
            """


# ============================================================
# Main pipeline targets
# ============================================================

rule all:
    input:
        # Phase 0
        "outputs/h5ad_validation_report.md",
        # Phase 1
        [ADATA_RAW[p] for p in PANELS],
        [ADATA_ANN[p] for p in PANELS],
        "results/adata.stromal.spatial.communities.h5ad",
        # Phase 3
        "outputs/celltype_validation_report.md",
        [ADATA_CELLTYPED[p] for p in PANELS],
        "metadata/lme_class_assignments.csv",
        # Figures
        "figures/manuscript/fig1/.done",
        "figures/manuscript/fig2/.done",
        "figures/manuscript/fig3/.done",
        "figures/manuscript/fig4/.done",
        "figures/manuscript/fig5/.done",
        expand("figures/manuscript/supp_fig{n}/.done", n=range(1, 9)),


rule phase0:
    input:
        "outputs/h5ad_validation_report.md",

rule phase1:
    input:
        [ADATA_RAW[p] for p in PANELS],
        [ADATA_ANN[p] for p in PANELS],
        "results/adata.stromal.spatial.communities.h5ad",

rule phase2:
    input:
        "outputs/celltype_validation_report.md",

rule phase3:
    input:
        [ADATA_CELLTYPED[p] for p in PANELS],
        "metadata/lme_class_assignments.csv",

rule figures:
    input:
        "figures/manuscript/fig1/.done",
        "figures/manuscript/fig2/.done",
        "figures/manuscript/fig3/.done",
        "figures/manuscript/fig4/.done",
        "figures/manuscript/fig5/.done",
        expand("figures/manuscript/supp_fig{n}/.done", n=range(1, 9)),


# ============================================================
# Phase 0: Data Audit
# ============================================================

rule download_clinical:
    """Download clinical/metadata files from cayuga backup."""
    output:
        manifest="metadata/download_manifest_phase0.csv",
    shell:
        "bash scripts/download_clinical_metadata.sh"


rule validate_h5ad:
    """Validate key h5ad objects."""
    output:
        report="outputs/h5ad_validation_report.md",
        csv="outputs/h5ad_validation_summary.csv",
    shell:
        "python scripts/validate_h5ad_objects.py"


# ============================================================
# Phase 1: AnnData Construction
# ============================================================

rule build_panel_adata:
    """Build panel-specific AnnData from Seurat-converted objects."""
    input:
        # Immune: T2 full
        immune=config["objects"]["immune_full"],
        # Stromal: S2 full
        stromal=config["objects"]["stromal_full"],
    output:
        immune="results/adata.immune.raw.h5ad",
        stromal="results/adata.stromal.raw.h5ad",
    shell:
        "python scripts/build_panel_adata.py --panel both"


rule attach_clinical:
    """Attach clinical metadata to panel AnnData."""
    input:
        immune=ADATA_RAW["immune"],
        stromal=ADATA_RAW["stromal"],
        manifest="metadata/download_manifest_phase0.csv",
    output:
        immune="results/adata.immune.annotated.h5ad",
        stromal="results/adata.stromal.annotated.h5ad",
    shell:
        "python scripts/attach_clinical_metadata.py --panel both"


rule build_spatial:
    """Build spatial community AnnData."""
    input:
        spatial=config["objects"]["spatial_communities"],
    output:
        "results/adata.stromal.spatial.communities.h5ad",
    shell:
        "python scripts/build_spatial_adata.py"


# ============================================================
# Phase 2-3: Validation + LME
# ============================================================

rule validate_celltypes:
    """Validate cell types by marker expression."""
    input:
        [ADATA_ANN[p] for p in PANELS],
    output:
        report="outputs/celltype_validation_report.md",
        immune_heatmap="figures/QC/celltype_marker_heatmap_immune.pdf",
        stromal_heatmap="figures/QC/celltype_marker_heatmap_stromal.pdf",
    shell:
        "python scripts/validate_celltypes.py --panel both"


rule build_lme_classes:
    """Assign LME classes and create celltype_manual checkpoints."""
    input:
        [ADATA_ANN[p] for p in PANELS],
        manifest="metadata/download_manifest_phase0.csv",
    output:
        expand("results/adata.{panel}.celltyped.h5ad", panel=PANELS),
        lme="metadata/lme_class_assignments.csv",
    shell:
        "python scripts/build_lme_classes.py --panel both"


