# ggo_visium Snakemake pipeline
# Run from repo root: snakemake -d projects/visium/ggo_visium -s projects/visium/ggo_visium/Snakefile [target]
# Or from project dir: snakemake -d . -s Snakefile [target]
# Uses run_container.sh (OS-aware: Docker on macOS, Apptainer on Linux).
# Override runtime: SC_TOOLS_RUNTIME=docker|apptainer; SIF: SC_TOOLS_SIF; Image: SC_TOOLS_IMAGE.
#
# ── Phase naming convention ───────────────────────────────────────────────────
# Uses SEMANTIC SLUG names (new nomenclature). Legacy p-code filenames are
# supported via _compat(): if an old-named file exists on disk and the new
# name does not, the old path is used so existing runs are not re-triggered.
#
#   Slug              Checkpoint file
#   metadata_attach   results/adata.annotated.h5ad
#   scoring           results/adata.scored.h5ad
#   celltype_manual   results/adata.celltyped.h5ad
#
# Note: ggo_visium uses project-specific names for Phase 1/3 checkpoints
# (adata.annotation.h5ad, scvi.leiden.h5ad) that predate the standard scheme.
# ─────────────────────────────────────────────────────────────────────────────

configfile: "config.yaml"

import os

ROOT = config["repo_root"]
PROJECT = config["project_rel"]

def run_container(script):
    return f'cd {ROOT} && ./scripts/run_container.sh {PROJECT} python {script}'

# ── Backwards-compat checkpoint resolver ─────────────────────────────────────
def _compat(new, old):
    return old if os.path.exists(old) and not os.path.exists(new) else new

ADATA_RAW       = _compat("results/adata.raw.h5ad",        "results/adata.raw.p1.h5ad")
ADATA_ANN       = _compat("results/adata.annotated.h5ad",  "results/adata.annotated.p2.h5ad")
ADATA_NORM      = _compat("results/adata.normalized.h5ad", "results/adata.normalized.p3.h5ad")
ADATA_SCORED    = _compat("results/adata.scored.h5ad",     "results/adata.normalized.scored.p35.h5ad")
ADATA_CELLTYPED = _compat("results/adata.celltyped.h5ad",  "results/adata.celltyped.p4.h5ad")

# ---- Phase 0: Upstream Raw Data Processing ----
import pandas as pd

PHASE0_DIR = "metadata/phase0"

def load_phase0_manifest():
    all_tsv = f"{PHASE0_DIR}/all_samples.tsv"
    if os.path.exists(all_tsv):
        return pd.read_csv(all_tsv, sep="\t")
    return pd.DataFrame()

PHASE0_MANIFEST = load_phase0_manifest()
PHASE0_SAMPLES = list(PHASE0_MANIFEST["sample_id"]) if len(PHASE0_MANIFEST) > 0 else []

rule spaceranger_count:
    output: directory("data/{sample_id}/outs")
    params:
        row=lambda wc: PHASE0_MANIFEST[PHASE0_MANIFEST["sample_id"] == wc.sample_id].iloc[0]
    threads: 16
    resources: mem_mb=64000
    shell:
        """
        spaceranger count \
            --id={wildcards.sample_id} \
            --transcriptome={config[transcriptome]} \
            --fastqs={params.row[fastq_dir]} \
            --image={params.row[image]} \
            --slide={params.row[slide]} \
            --area={params.row[area]} \
            --localcores={threads} --localmem=64 \
            --output-dir=data/{wildcards.sample_id}
        """

rule ingest_raw:
    input: expand("data/{sample_id}/outs", sample_id=PHASE0_SAMPLES)

# ---- qc_filter / Phase 1: Data Ingestion & QC ----
rule adata_annotation:
    output: "results/adata.annotation.h5ad"
    input: "scripts/loupe2adata.py"
    shell: run_container("scripts/loupe2adata.py")

rule adata_metadata_attach:
    output: "results/adata.annotated.h5ad"
    input: "results/adata.annotation.h5ad", "scripts/annotation2mask_img.py"
    shell: run_container("scripts/annotation2mask_img.py")

rule validate_metadata_attach:
    input: ADATA_ANN
    output: touch("results/.adata.annotated.validated")
    shell: f"cd {{ROOT}} && python scripts/validate_checkpoint.py {{PROJECT}}/{ADATA_ANN} --phase metadata_attach --fix"

rule metadata_attach:
    input: ADATA_ANN, "results/.adata.annotated.validated"

# ---- Phase 2: Metadata Attachment ----
# (metadata already joined in Phase 1 for this project)

# ---- Phase 3: Preprocessing ----
rule scvi_h5ad:
    output: "results/scvi.h5ad"
    input: ADATA_ANN, "scripts/preprocessing.py"
    shell: run_container("scripts/preprocessing.py")

rule scvi_leiden:
    output: "results/scvi.leiden.h5ad"
    input: "results/scvi.h5ad", "scripts/clustering.py"
    shell: run_container("scripts/clustering.py")

rule preprocess:
    input: "results/scvi.leiden.h5ad"

# ---- scoring: Gene Scoring, Automated Cell Typing, Deconvolution ----
rule scvi_leiden_phenotyped:
    output: "results/scvi.leiden.phenotyped.h5ad"
    input: "results/scvi.leiden.h5ad", "scripts/celltyping.py"
    shell: run_container("scripts/celltyping.py")

rule adata_scoring:
    output: "results/adata.scored.h5ad"
    input: ADATA_ANN, "results/.adata.annotated.validated", "metadata/gene_signatures.json", "scripts/score_gene_signatures.py"
    shell: run_container("scripts/score_gene_signatures.py")

rule validate_scoring:
    input: ADATA_SCORED
    output: touch("results/.adata.scored.validated")
    shell: f"cd {{ROOT}} && python scripts/validate_checkpoint.py {{PROJECT}}/{ADATA_SCORED} --phase scoring --fix"

DECONV_METHOD = config.get("deconv_method", "cell2location")

rule adata_deconvolution:
    output: f"results/adata.deconvolution.{DECONV_METHOD}.h5ad"
    input: ADATA_SCORED, "results/seurat_object.h5ad", "scripts/celltype_deconvolution.py"
    shell: run_container("scripts/celltype_deconvolution.py") + f" --method {DECONV_METHOD}"

rule deconvolution_spatial_plot:
    output:
        pdf=f"figures/deconvolution/{DECONV_METHOD}/spatial_proportions.{DECONV_METHOD}.pdf",
        done=touch(f"figures/deconvolution/{DECONV_METHOD}/.pngs.done"),
    input: f"results/adata.deconvolution.{DECONV_METHOD}.h5ad"
    shell:
        (
            run_container(ROOT + "/scripts/plot_deconvolution_spatial.py")
            + f" --input results/adata.deconvolution.{DECONV_METHOD}.h5ad"
            + f" --output figures/deconvolution/{DECONV_METHOD}/spatial_proportions.{DECONV_METHOD}.pdf"
            + " --batch-key library_id"
        )

rule deconvolution:
    input:
        f"results/adata.deconvolution.{DECONV_METHOD}.h5ad",
        f"figures/deconvolution/{DECONV_METHOD}/spatial_proportions.{DECONV_METHOD}.pdf",

rule scoring:
    input:
        "results/scvi.leiden.phenotyped.h5ad",
        ADATA_SCORED,
        f"results/adata.deconvolution.{DECONV_METHOD}.h5ad",
        f"figures/deconvolution/{DECONV_METHOD}/spatial_proportions.{DECONV_METHOD}.pdf",

# ---- QC reports (date-versioned HTML) ----
rule qc_pre_filter:
    input: ADATA_RAW
    output: touch("figures/QC/pre_filter_qc.done")
    shell: (
        run_container(ROOT + "/scripts/run_qc_report.py")
        + f" --report pre_filter --adata {ADATA_RAW} --figures-dir figures --modality visium"
    )

rule qc_post_filter:
    input: ADATA_RAW, ADATA_ANN
    output: touch("figures/QC/post_filter_qc.done")
    shell: (
        run_container(ROOT + "/scripts/run_qc_report.py")
        + f" --report post_filter --adata {ADATA_RAW}"
        + f" --adata-post {ADATA_ANN} --figures-dir figures --modality visium"
    )

rule qc_post_integration:
    input: ADATA_NORM
    output: touch("figures/QC/post_integration_qc.done")
    shell: (
        run_container(ROOT + "/scripts/run_qc_report.py")
        + f" --report post_integration --adata-integrated {ADATA_NORM}"
        + " --figures-dir figures --modality visium"
    )

rule qc_post_celltyping:
    input: ADATA_CELLTYPED
    output: touch("figures/QC/post_celltyping_qc.done")
    shell: (
        run_container(ROOT + "/scripts/run_qc_report.py")
        + f" --report post_celltyping --adata-integrated {ADATA_CELLTYPED}"
        + " --celltype-key celltype"
        + " --integration-test-dir results/tmp/integration_test"
        + " --figures-dir figures --modality visium"
    )

rule qc_report:
    input: rules.qc_pre_filter.output, rules.qc_post_filter.output, rules.qc_post_integration.output, rules.qc_post_celltyping.output
    output: touch("figures/QC/qc_report.done")

# ---- Phase 5: Downstream Biology ----
rule tls_clustered:
    output: "results/tls_clustered.h5ad"
    input: ADATA_SCORED, "scripts/create_tls_anndata.py"
    shell: run_container("scripts/create_tls_anndata.py")

rule tls_analysis:
    output: touch("figures/manuscript/tls_analysis/.done")
    input: ADATA_SCORED, "results/tls_clustered.h5ad", "scripts/tls_analysis.py"
    shell: run_container("scripts/tls_analysis.py") + " && mkdir -p figures/manuscript/tls_analysis && touch figures/manuscript/tls_analysis/.done"

rule spatial_analysis:
    output: touch("figures/manuscript/spatial_analysis/.done")
    input: ADATA_SCORED, "scripts/spatial_analysis.py"
    shell: run_container("scripts/spatial_analysis.py") + " && mkdir -p figures/manuscript/spatial_analysis && touch figures/manuscript/spatial_analysis/.done"

rule tumor_differences:
    output: touch("figures/manuscript/tumor_differences/.done")
    input: ADATA_SCORED, "scripts/tumor_differences.py"
    shell: run_container("scripts/tumor_differences.py") + " && mkdir -p figures/manuscript/tumor_differences && touch figures/manuscript/tumor_differences/.done"

