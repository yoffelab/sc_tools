# ggo_visium Snakemake pipeline
# Run from repo root: snakemake -d projects/visium/ggo_visium -s projects/visium/ggo_visium/Snakefile [target]
# Or from project dir: snakemake -d . -s Snakefile [target]
# Uses run_container.sh (OS-aware: Docker on macOS, Apptainer on Linux).
# Override runtime: SC_TOOLS_RUNTIME=docker|apptainer; SIF: SC_TOOLS_SIF; Image: SC_TOOLS_IMAGE.

configfile: "config.yaml"

import os

ROOT = config["repo_root"]
PROJECT = config["project_rel"]

def run_container(script):
    return f'cd {ROOT} && ./scripts/run_container.sh {PROJECT} python {script}'

# ---- Phase 0: Upstream Raw Data Processing ----
import pandas as pd

PHASE0_DIR = "metadata/phase0"

def load_phase0_manifest():
    all_tsv = f"{PHASE0_DIR}/all_samples.tsv"
    if os.path.exists(all_tsv):
        return pd.read_csv(all_tsv, sep="\t")
    return pd.DataFrame()

PHASE0_MANIFEST = load_phase0_manifest()
PHASE0_SAMPLES = list(PHASE0_MANIFEST["sample_id"]) if len(PHASE0_MANIFEST) > 0 else []

rule spaceranger_count:
    output: directory("data/{sample_id}/outs")
    params:
        row=lambda wc: PHASE0_MANIFEST[PHASE0_MANIFEST["sample_id"] == wc.sample_id].iloc[0]
    threads: 16
    resources: mem_mb=64000
    shell:
        """
        spaceranger count \
            --id={wildcards.sample_id} \
            --transcriptome={config[transcriptome]} \
            --fastqs={params.row[fastq_dir]} \
            --image={params.row[image]} \
            --slide={params.row[slide]} \
            --area={params.row[area]} \
            --localcores={threads} --localmem=64 \
            --output-dir=data/{wildcards.sample_id}
        """

rule phase0:
    input: expand("data/{sample_id}/outs", sample_id=PHASE0_SAMPLES)

# ---- Phase 1: Data Ingestion & QC ----
rule adata_annotation:
    output: "results/adata.annotation.h5ad"
    input: "scripts/loupe2adata.py"
    shell: run_container("scripts/loupe2adata.py")

rule adata_annotated_p2:
    output: "results/adata.annotated.p2.h5ad"
    input: "results/adata.annotation.h5ad", "scripts/annotation2mask_img.py"
    shell: run_container("scripts/annotation2mask_img.py")

rule validate_p2:
    input: "results/adata.annotated.p2.h5ad"
    output: touch("results/.adata.annotated.p2.validated")
    shell: f"cd {{ROOT}} && python scripts/validate_checkpoint.py {{PROJECT}}/results/adata.annotated.p2.h5ad --phase p2 --fix"

rule phase1:
    input: "results/adata.annotated.p2.h5ad", "results/.adata.annotated.p2.validated"

# ---- Phase 2: Metadata Attachment ----
# (metadata already joined in Phase 1 for this project)

# ---- Phase 3: Preprocessing ----
rule scvi_h5ad:
    output: "results/scvi.h5ad"
    input: "results/adata.annotated.p2.h5ad", "scripts/preprocessing.py"
    shell: run_container("scripts/preprocessing.py")

rule scvi_leiden:
    output: "results/scvi.leiden.h5ad"
    input: "results/scvi.h5ad", "scripts/clustering.py"
    shell: run_container("scripts/clustering.py")

rule phase3:
    input: "results/scvi.leiden.h5ad"

# ---- Phase 3.5b: Gene Scoring, Automated Cell Typing, Deconvolution ----
rule scvi_leiden_phenotyped:
    output: "results/scvi.leiden.phenotyped.h5ad"
    input: "results/scvi.leiden.h5ad", "scripts/celltyping.py"
    shell: run_container("scripts/celltyping.py")

rule adata_p35:
    output: "results/adata.normalized.scored.p35.h5ad"
    input: "results/adata.annotated.p2.h5ad", "results/.adata.annotated.p2.validated", "metadata/gene_signatures.json", "scripts/score_gene_signatures.py"
    shell: run_container("scripts/score_gene_signatures.py")

rule validate_p35:
    input: "results/adata.normalized.scored.p35.h5ad"
    output: touch("results/.adata.normalized.scored.p35.validated")
    shell: f"cd {{ROOT}} && python scripts/validate_checkpoint.py {{PROJECT}}/results/adata.normalized.scored.p35.h5ad --phase p35 --fix"

DECONV_METHOD = config.get("deconv_method", "cell2location")

rule adata_deconvolution:
    output: f"results/adata.deconvolution.{DECONV_METHOD}.h5ad"
    input: "results/adata.normalized.scored.p35.h5ad", "results/seurat_object.h5ad", "scripts/celltype_deconvolution.py"
    shell: run_container("scripts/celltype_deconvolution.py") + f" --method {DECONV_METHOD}"

rule deconvolution_spatial_plot:
    output:
        pdf=f"figures/deconvolution/{DECONV_METHOD}/spatial_proportions.{DECONV_METHOD}.pdf",
        done=touch(f"figures/deconvolution/{DECONV_METHOD}/.pngs.done"),
    input: f"results/adata.deconvolution.{DECONV_METHOD}.h5ad"
    shell:
        (
            run_container(ROOT + "/scripts/plot_deconvolution_spatial.py")
            + f" --input results/adata.deconvolution.{DECONV_METHOD}.h5ad"
            + f" --output figures/deconvolution/{DECONV_METHOD}/spatial_proportions.{DECONV_METHOD}.pdf"
            + " --batch-key library_id"
        )

rule deconvolution:
    input:
        f"results/adata.deconvolution.{DECONV_METHOD}.h5ad",
        f"figures/deconvolution/{DECONV_METHOD}/spatial_proportions.{DECONV_METHOD}.pdf",

rule phase35b:
    input:
        "results/scvi.leiden.phenotyped.h5ad",
        "results/adata.normalized.scored.p35.h5ad",
        f"results/adata.deconvolution.{DECONV_METHOD}.h5ad",
        f"figures/deconvolution/{DECONV_METHOD}/spatial_proportions.{DECONV_METHOD}.pdf",

# ---- QC report (Phase 1 style: 2x2, 2x4, multipage, violin, scatter, HVG, SVG) ----
rule qc_report:
    output: touch("figures/QC/qc_report.done")
    input: "results/adata.annotated.p2.h5ad", "results/adata.normalized.scored.p35.h5ad"
    shell: (
        run_container(ROOT + "/scripts/run_qc_report.py")
        + " --raw results/adata.annotated.p2.h5ad --post results/adata.normalized.scored.p35.h5ad --figures-dir figures"
        + " && touch figures/QC/qc_report.done"
    )

# ---- Phase 4: Manual Cell Typing (skippable) ----
rule tls_clustered:
    output: "results/tls_clustered.h5ad"
    input: "results/adata.normalized.scored.p35.h5ad", "scripts/create_tls_anndata.py"
    shell: run_container("scripts/create_tls_anndata.py")

