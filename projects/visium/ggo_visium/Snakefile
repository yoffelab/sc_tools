    output: touch("figures/manuscript/macrophage_localization/.done")
    input: ADATA_SCORED, "scripts/macrophage_localization.py"
    shell: run_container("scripts/macrophage_localization.py") + " && mkdir -p figures/manuscript/macrophage_localization figures/stats && touch figures/manuscript/macrophage_localization/.done"

rule neutrophil_cytotoxic_tcell_localization:
    output: touch("figures/manuscript/neutrophil_cytotoxic_tcell_localization/.done")
    input: ADATA_SCORED, "scripts/neutrophil_cytotoxic_tcell_localization.py"
    shell: run_container("scripts/neutrophil_cytotoxic_tcell_localization.py") + " && mkdir -p figures/manuscript/neutrophil_cytotoxic_tcell_localization figures/stats && touch figures/manuscript/neutrophil_cytotoxic_tcell_localization/.done"

